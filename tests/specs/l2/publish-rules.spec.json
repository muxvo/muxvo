{
  "module": "PUBLISH",
  "layer": "L2",
  "category": "publish-rules",
  "source": "tests/l2/v2-content.test.ts",
  "docSource": "docs/Muxvo_测试_v2/02_modules/test_V2_CONTENT.md",
  "fixtureSource": "tests/helpers/test-fixtures.ts (securityPatterns, imageFixtures)",
  "totalCases": 8,
  "cases": [
    {
      "id": "PUBLISH_L2_01",
      "description": "截图最多 5 张限制",
      "type": "validation-rule",
      "rule": "max-screenshots",
      "input": { "screenshotCount": 6 },
      "expected": {
        "blocked": true,
        "reason": "截图/GIF 最多 5 张"
      },
      "boundary": { "max": 5 },
      "priority": "P1"
    },
    {
      "id": "PUBLISH_L2_02",
      "description": "文件大小警告 — Skill 超 1MB",
      "type": "validation-rule",
      "rule": "file-size-check",
      "input": {
        "fileType": "skill",
        "fileSizeBytes": 1572864
      },
      "expected": {
        "blocked": false,
        "warning": true,
        "reason": "Skill 文件超过 1MB，建议精简"
      },
      "threshold": { "skillLimit": 1048576, "unit": "bytes" },
      "formula": "fileSizeBytes(1572864) > skillLimit(1048576) -> warn",
      "priority": "P1"
    },
    {
      "id": "PUBLISH_L2_03",
      "description": "首次发布版本 1.0.0",
      "type": "validation-rule",
      "rule": "initial-version",
      "input": { "previouslyPublished": false },
      "expected": {
        "version": "1.0.0"
      },
      "priority": "P1"
    },
    {
      "id": "PUBLISH_L2_05",
      "description": "阻止发布 — 检测到 API Key",
      "type": "validation-rule",
      "rule": "security-check",
      "input": { "content": "const key = 'sk-proj-abc123def456';" },
      "patterns": [
        "/sk-[a-zA-Z0-9]+/",
        "/ghp_[a-zA-Z0-9]+/",
        "/token_[a-zA-Z0-9]+/"
      ],
      "expected": {
        "blocked": true,
        "reason": "检测到敏感信息",
        "matchedPattern": "/sk-[a-zA-Z0-9]+/"
      },
      "priority": "P0"
    },
    {
      "id": "PUBLISH_L2_06",
      "description": "阻止发布 — 敏感文件",
      "type": "validation-rule",
      "rule": "sensitive-file-check",
      "input": {
        "fileList": ["SKILL.md", "index.ts", ".env", "utils.ts"]
      },
      "sensitiveFiles": [".env", "credentials.json", "*.pem", "*.key"],
      "expected": {
        "blocked": true,
        "reason": "包含敏感文件",
        "detectedFiles": [".env"]
      },
      "priority": "P0"
    },
    {
      "id": "PUBLISH_L2_07",
      "description": "警告 — 硬编码路径",
      "type": "validation-rule",
      "rule": "hardcoded-path-check",
      "input": { "content": "const dir = '/Users/rl/projects/my-skill';" },
      "patterns": [
        "/\\/Users\\/[^/]+\\//",
        "/\\/home\\/[^/]+\\//i"
      ],
      "expected": {
        "blocked": false,
        "warning": true,
        "reason": "检测到硬编码路径",
        "userCanOverride": true
      },
      "priority": "P1"
    },
    {
      "id": "PUBLISH_L2_08",
      "description": "Plugin 文件大小警告 — 超 10MB",
      "type": "validation-rule",
      "rule": "file-size-check",
      "input": {
        "fileType": "plugin",
        "fileSizeBytes": 12582912
      },
      "expected": {
        "blocked": false,
        "warning": true,
        "reason": "Plugin 文件超过 10MB，建议精简"
      },
      "threshold": { "pluginLimit": 10485760, "unit": "bytes" },
      "formula": "fileSizeBytes(12582912) > pluginLimit(10485760) -> warn",
      "priority": "P2"
    },
    {
      "id": "PUBLISH_L2_14",
      "description": "分享面板 7 渠道完整性",
      "type": "validation-rule",
      "rule": "share-channels-completeness",
      "input": { "publishSuccess": true },
      "expected": {
        "channelCount": 7,
        "channels": [
          "Twitter/X",
          "LinkedIn",
          "微信",
          "复制链接",
          "复制徽章",
          "Discord",
          "Reddit"
        ]
      },
      "priority": "P1"
    }
  ]
}
