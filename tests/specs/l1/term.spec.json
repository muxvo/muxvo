  "source": "tests/l1/term.test.ts",
  "docSource": "docs/Muxvo_测试_v2/02_modules/test_TERM.md",
  "totalCases": 19,
  "cases": [
    {
      "id": "TERM_L1_01",
      "description": "terminal:create IPC 格式 -- 发送 { cwd } 返回 { terminalId, pid }",
      "type": "ipc",
      "channel": "terminal:create",
      "direction": "invoke",
      "input": {
        "cwd": "~/project"
      },
      "expectedResponse": {
        "terminalId": "string",
        "pid": "number"
      },
      "priority": "P0"
    },
    {
      "id": "TERM_L1_02",
      "description": "terminal:write IPC 格式 -- 发送 { terminalId, data } 返回 { success }",
      "type": "ipc",
      "channel": "terminal:write",
      "direction": "invoke",
      "input": {
        "terminalId": "t1",
        "data": "ls\n"
      },
      "expectedResponse": {
        "success": true
      },
      "priority": "P0"
    },
    {
      "id": "TERM_L1_03",
      "description": "terminal:resize IPC 格式 -- 发送 { terminalId, cols, rows } 返回 { success }",
      "type": "ipc",
      "channel": "terminal:resize",
      "direction": "invoke",
      "input": {
        "terminalId": "t1",
        "cols": 80,
        "rows": 24
      },
      "expectedResponse": {
        "success": true
      },
      "priority": "P1"
    },
    {
      "id": "TERM_L1_04",
      "description": "terminal:close IPC 格式 -- 发送 { terminalId } 返回 { success }",
      "type": "ipc",
      "channel": "terminal:close",
      "direction": "invoke",
      "input": {
        "terminalId": "t1"
      },
      "expectedResponse": {
        "success": true
      },
      "priority": "P0"
    },
    {
      "id": "TERM_L1_05",
      "description": "terminal:output push 格式 -- Renderer 收到 { terminalId, data }",
      "type": "ipc-push",
      "channel": "terminal:output",
      "expectedPayload": {
        "terminalId": "string",
        "data": "string"
      },
      "priority": "P0"
    },
    {
      "id": "TERM_L1_06",
      "description": "terminal:state-change push 格式 -- Renderer 收到 { terminalId, state }",
      "type": "ipc-push",
      "channel": "terminal:state-change",
      "expectedPayload": {
        "terminalId": "string",
        "state": "string"
      },
      "priority": "P0"
    },
    {
      "id": "TERM_L1_07",
      "description": "terminal:exit push 格式 -- Renderer 收到 { terminalId, exitCode }",
      "type": "ipc-push",
      "channel": "terminal:exit",
      "expectedPayload": {
        "terminalId": "string",
        "exitCode": "number"
      },
      "priority": "P0"
    },
