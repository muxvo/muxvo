          "action": "click to expand"
        },
        "toolResult": {
          "borderLeft": "green",
          "defaultState": "collapsed"
        }
      },
      "priority": "P1"
    },
    {
      "id": "CHAT_L1_13",
      "description": "同步状态 UI -- 面板底部显示\"Muxvo 镜像 -- 最后同步 HH:MM\"",
