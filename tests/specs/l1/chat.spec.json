  "cases": [
    {
      "id": "CHAT_L1_01",
      "description": "chat:get-history IPC 格式 -- 返回 { sessions: Array<SessionSummary> }",
      "type": "ipc",
      "channel": "chat:get-history",
      "direction": "invoke",
      "input": null,
      "expectedResponse": {
        "sessions": "Array<{sessionId: string, project: string, projectHash: string, title: string, timestamp: number, messageCount: number}>"
      },
      "statePath": "Closed -> Loading -> Ready",
      "priority": "P0"
    },
    {
      "id": "CHAT_L1_02",
      "description": "chat:get-session IPC 格式 -- 传入 sessionId+projectHash 返回 messages 数组",
      "type": "ipc",
      "channel": "chat:get-session",
      "direction": "invoke",
      "input": {
        "sessionId": "string",
        "projectHash": "string"
      },
      "expectedResponse": {
        "messages": "Array<{type: string, message: string, timestamp: string, cwd: string}>"
      },
      "priority": "P0"
    },
    {
      "id": "CHAT_L1_03",
      "description": "chat:search IPC 格式 -- 传入 query 返回匹配 sessions",
      "type": "ipc",
      "channel": "chat:search",
      "direction": "invoke",
      "input": {
        "query": "test"
      },
      "expectedResponse": {
        "results": "Array<{sessionId: string, matches: number, context: string}>"
      },
      "priority": "P0"
    },
    {
      "id": "CHAT_L1_04",
      "description": "chat:get-history 错误响应 -- CC 文件不可用时返回统一错误格式",
      "type": "ipc",
      "channel": "chat:get-history",
      "direction": "invoke",
      "condition": "CC files and mirror both unavailable",
      "expectedResponse": {
        "code": "FILE_NOT_FOUND",
        "message": "string"
      },
      "priority": "P1"
    },
    {
      "id": "CHAT_L1_05",
      "description": "chat:export IPC 格式 -- 导出为 Markdown 格式",
      "type": "ipc",
      "channel": "chat:export",
      "direction": "invoke",
      "input": {
        "sessionId": "string",
        "format": "md"
      },
      "expectedResponse": {
        "filePath": "string"
      },
      "priority": "P1"
    },
    {
      "id": "CHAT_L1_06",
      "description": "chat:session-update 推送格式 -- 后台同步推送新/更新 session",
      "type": "ipc-push",
      "channel": "chat:session-update",
      "expectedPayload": {
        "sessionId": "string",
        "action": "\"added\"|\"updated\"",
        "data": "object"
      },
      "priority": "P0"
    },
    {
      "id": "CHAT_L1_07",
      "description": "chat:sync-status 推送格式 -- 同步状态变化通知",
      "type": "ipc-push",
      "channel": "chat:sync-status",
      "expectedPayload": {
        "status": "\"syncing\"|\"done\"|\"error\"",
        "lastSync": "string",
        "progress": "number (optional)"
      },
      "priority": "P1"
    },
    {
      "id": "CHAT_L1_08",
      "description": "默认选中全部项目 -- 左栏\"全部项目\"默认高亮",
      "type": "default-value",
      "target": "chatHistory.selectedProject",
      "expectedValue": "全部项目",
      "expectedUI": {
        "leftPanel": "\"全部项目\" highlighted",
        "middlePanel": "shows all sessions"
      },
      "priority": "P0"
    },
    {
      "id": "CHAT_L1_09",
      "description": "三栏默认布局 -- 左栏 220px, 中栏 340px, 右栏 flex",
      "type": "default-value",
      "target": "chatHistory.layout",
      "expectedValue": {
        "left": "220px",
        "middle": "340px",
        "right": "flex"
      },
      "priority": "P0"
    },
    {
      "id": "CHAT_L1_10",
      "description": "会话卡片默认字段 -- 标题/时间/预览/标签/tool calls 数",
      "type": "default-value",
      "target": "chatHistory.sessionCardFields",
      "expectedValue": {
        "fields": ["title", "time", "preview", "tags", "toolCallCount"],
        "timeFormat": "today:HH:MM / yesterday / MM-DD",
        "previewTruncate": "2 lines"
