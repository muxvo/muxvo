        "theme": "string",
        "fontSize": "number"
      },
      "priority": "P0"
    },
    {
      "id": "APP_L1_02",
      "description": "app:save-config IPC 格式 -- 传入配置对象返回 { success }",
      "type": "ipc",
      "channel": "app:save-config",
      "direction": "invoke",
      "input": {
        "config": "object"
      },
      "expectedResponse": {
        "success": "boolean"
      },
      "sideEffect": "config.json file updated",
      "priority": "P0"
    },
