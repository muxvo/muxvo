# Environment
NODE_ENV=development

# Server
PORT=3100
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://localhost:5432/muxvo
REDIS_URL=redis://localhost:6379

# JWT (RSA key-pair, used by src/lib/jwt.ts)
JWT_PRIVATE_KEY_PATH=./jwt-private.pem
JWT_PUBLIC_KEY_PATH=./jwt-public.pem
JWT_KEY_ID=muxvo-auth-key-v1

# GitHub OAuth (需要你自己去 https://github.com/settings/developers 创建)
GITHUB_CLIENT_ID=Ov23liNRn82V5vDkjVS2
GITHUB_CLIENT_SECRET=f97df54264c7dbda4b148432e03fac964dd56ef0
GITHUB_CALLBACK_URL=https://api.muxvo.com/auth/github/callback

# Google OAuth (需要你自己去 https://console.cloud.google.com 创建)
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GOOGLE_CALLBACK_URL=https://api.muxvo.com/auth/google/callback

# App scheme (for OAuth redirect back to Electron app)
APP_SCHEME=muxvo

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM=noreply@muxvo.com

# Docker DB password (used by docker-compose.yml)
DB_PASSWORD=
