NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://muxvo:password@localhost:5432/muxvo_dev
REDIS_URL=redis://localhost:6379
# Production uses /app/data/jwt-*.pem (Docker named volume)
JWT_PRIVATE_KEY_PATH=./jwt-private.pem
JWT_PUBLIC_KEY_PATH=./jwt-public.pem
JWT_KEY_ID=muxvo-auth-key-v1
# OAuth — production values managed via GitHub Secrets → deploy-server.yml
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.muxvo.com/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.muxvo.com/auth/google/callback
APP_SCHEME=muxvo
RESEND_API_KEY=
EMAIL_FROM=noreply@muxvo.com
# Docker DB password (used by docker-compose.yml ${DB_PASSWORD})
DB_PASSWORD=
