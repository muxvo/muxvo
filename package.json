{
  "name": "muxvo",
  "version": "0.1.9",
  "private": true,
  "description": "Electron desktop workbench for AI CLI tools",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "rm -rf out/renderer && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "verify:coverage": "tsx tests/scripts/verify-coverage.ts",
    "pretest": "tsx tests/scripts/verify-coverage.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:l1": "vitest run tests/l1/",
    "test:l2": "vitest run tests/l2/",
    "test:l3": "vitest run tests/l3/",
    "test:coverage": "vitest run --coverage",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper node_modules/node-pty/prebuilds/darwin-x64/spawn-helper 2>/dev/null; echo 'node-pty spawn-helper permissions fixed'"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@iarna/toml": "^2.2.5",
    "@tiptap/markdown": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "driver.js": "^1.4.0",
    "electron-updater": "^6.8.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-virtuoso": "^4.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
